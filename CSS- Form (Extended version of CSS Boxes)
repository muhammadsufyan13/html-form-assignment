<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>

    <link rel="stylesheet" href="login.css">

    <!-- ICONS (Font Awesome) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="logo">MyLogo</div>

        <div class="login-btn">
            <div class="avatar"></div>
            <span>Login</span>
        </div>
    </nav>

    <!-- LOGIN FORM -->
    <div class="container">
        <form class="login-form">

            <div class="input-box">
                <i class="fa fa-envelope"></i>
                <input type="email" placeholder="Enter Email" required>
            </div>

            <div class="input-box">
                <i class="fa fa-lock"></i>
                <input type="password" placeholder="Enter Password" required>
            </div>

            <div class="buttons">
                <button type="submit">Login</button>
                <a href="#">Don't have an account?</a>
            </div>

        </form>
    </div>

</body>
</html>










CSS :




* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
}

/* NAVBAR */
.navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 20px;
    border: 2px solid black;
}

.logo {
    font-weight: bold;
    font-size: 20px;
}

.login-btn {
    display: flex;
    align-items: center;
    gap: 10px;
}

.avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid black;
}

/* CENTER FORM */
.container {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 80vh;
}

/* FORM BOX */
.login-form {
    width: 350px;
    padding: 30px;
    border: 2px solid black;
}

/* INPUT BOX */
.input-box {
    display: flex;
    align-items: center;
    border: 2px solid black;
    margin-bottom: 15px;
    padding: 10px;
}

.input-box i {
    margin-right: 10px;
}

.input-box input {
    border: none;
    outline: none;
    width: 100%;
}

/* BUTTONS */
.buttons {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

button {
    padding: 8px 20px;
    border: 2px solid black;
    background: white;
    cursor: pointer;
}

button:hover {
    background: black;
    color: white;
}

.buttons a {
    text-decoration: none;
    font-size: 12px;
}
